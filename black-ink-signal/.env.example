# Black Ink Signal — Environment Configuration
# Copy this to .env and fill in your values.

# ---------------------------------------------------------------------------
# Reddit OAuth (optional — falls back to public JSON if not set)
# ---------------------------------------------------------------------------
# Create a Reddit "script" app at https://www.reddit.com/prefs/apps
# BIS_REDDIT_CLIENT_ID=your_client_id_here
# BIS_REDDIT_CLIENT_SECRET=your_client_secret_here
# BIS_REDDIT_USERNAME=your_reddit_username
# BIS_REDDIT_PASSWORD=your_reddit_password
# BIS_REDDIT_USER_AGENT=BlackInkSignal/0.1 (by /u/your_username)

# ---------------------------------------------------------------------------
# Scheduler
# ---------------------------------------------------------------------------
BIS_REDDIT_INTERVAL=5
BIS_ENRICHMENT_INTERVAL=2
BIS_ENRICHMENT_BATCH=20

# ---------------------------------------------------------------------------
# Notifications
# ---------------------------------------------------------------------------
BIS_HOT_LEAD_THRESHOLD=80
BIS_NOTIFICATION_COOLDOWN=30

# ---------------------------------------------------------------------------
# LLM Enrichment (optional — falls back to rule-based)
# ---------------------------------------------------------------------------
# BIS_LLM_API_KEY=your_openai_key_here
# BIS_LLM_API_BASE=https://api.openai.com/v1
# BIS_LLM_MODEL=gpt-4o-mini
