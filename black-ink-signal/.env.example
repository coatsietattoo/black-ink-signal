# Black Ink Signal — Environment Configuration
# Copy to .env and fill in your values. Uncomment lines to activate.

# ===========================================================================
# Reddit OAuth (required for real data from cloud/server IPs)
# ===========================================================================
# Create a script app at https://www.reddit.com/prefs/apps
# BIS_REDDIT_CLIENT_ID=
# BIS_REDDIT_CLIENT_SECRET=
# BIS_REDDIT_USERNAME=
# BIS_REDDIT_PASSWORD=
# BIS_REDDIT_USER_AGENT=BlackInkSignal/0.1 (by /u/your_username)

# ===========================================================================
# API Server
# ===========================================================================
BIS_API_HOST=127.0.0.1
BIS_API_PORT=8787

# ===========================================================================
# Database
# ===========================================================================
# Path relative to project root, or absolute path
BIS_DB_PATH=data/black_ink_signal.db

# ===========================================================================
# Scheduler Intervals (minutes)
# ===========================================================================
BIS_REDDIT_INTERVAL=5
BIS_ENRICHMENT_INTERVAL=2
BIS_ENRICHMENT_BATCH=20

# ===========================================================================
# Notifications
# ===========================================================================
BIS_HOT_LEAD_THRESHOLD=80
BIS_NOTIFICATION_COOLDOWN=30

# ===========================================================================
# LLM Enrichment (optional — rule-based always runs)
# ===========================================================================
# Supports any OpenAI-compatible endpoint (OpenAI, Ollama, LiteLLM, etc.)
# BIS_LLM_API_KEY=
# BIS_LLM_API_BASE=https://api.openai.com/v1
# BIS_LLM_MODEL=gpt-4o-mini

# ===========================================================================
# Subreddits to monitor (comma-separated)
# ===========================================================================
BIS_SUBREDDITS=tattoos,tattoodesigns,tattoo,Edmonton,alberta,tattooadvice

# ===========================================================================
# Target location (for geo scoring context)
# ===========================================================================
BIS_TARGET_CITY=Edmonton
BIS_TARGET_REGION=Alberta
